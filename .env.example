# Copy to .env and fill in values. .env is gitignored.

# HuggingFace access token (read scope is sufficient for public datasets;
# write scope is only needed if you push your own datasets).
# Get one at https://huggingface.co/settings/tokens
# Either name is accepted; HF_TOKEN takes precedence.
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Google Gemini API key (only required for the AI-enriched analysis features).
# Get one at https://aistudio.google.com/apikey
# Either name is accepted; GEMINI_API_KEY takes precedence.
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Where downloaded datasets are cached. Defaults to ./data relative to repo root.
# DATA_ROOT=./data

# Backend bind address & port (defaults shown).
# HOST=0.0.0.0
# PORT=8000
